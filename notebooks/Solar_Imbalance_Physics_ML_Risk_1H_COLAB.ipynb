   "cell_type": "code",
   "execution_count": null,
   "id": "626cf266",
   "metadata": {},
   "outputs": [],
   "source": [
    "def regression_metrics_safe(y_true, y_pred):\n",
    "    rmse = np.sqrt(mean_squared_error(y_true, y_pred))\n",
    "    mae = mean_absolute_error(y_true, y_pred)\n",
    "    r2 = r2_score(y_true, y_pred)\n",
    "    return {'RMSE': rmse, 'MAE': mae, 'R2': r2}\n",
    "\n",
    "metrics_1h = pd.DataFrame({\n",
    "    'Baseline Persistence': regression_metrics_safe(test_1h[TARGET_1H], test_1h['pred_baseline_1h']),\n",
    "    'Standard ML': regression_metrics_safe(test_1h[TARGET_1H], test_1h['pred_standard_ml_1h']),\n",
    "    'Physics-Informed ML': regression_metrics_safe(test_1h[TARGET_1H], test_1h['pred_physics_ml_1h']),\n",
    "}).T\n",
    "\n",
    "metrics_1h['RMSE improvement vs baseline'] = 1 - metrics_1h['RMSE'] / metrics_1h.loc['Baseline Persistence', 'RMSE']\n",
    "metrics_1h['MAE improvement vs baseline'] = 1 - metrics_1h['MAE'] / metrics_1h.loc['Baseline Persistence', 'MAE']\n",
    "\n",
    "display(metrics_1h)\n",
    "\n",
    "# Combine with the original 15-minute metrics from earlier.\n",
    "metrics_15m_labeled = metrics.copy()\n",
    "metrics_15m_labeled['Horizon'] = '15-minute'\n",
    "metrics_1h_labeled = metrics_1h.copy()\n",
    "metrics_1h_labeled['Horizon'] = '1-hour'\n",
    "\n",
    "combined_metrics = pd.concat([metrics_15m_labeled, metrics_1h_labeled])\n",
    "combined_metrics = combined_metrics.reset_index().rename(columns={'index': 'Model'})\n",
    "\n",
    "display(combined_metrics[['Horizon', 'Model', 'RMSE', 'MAE', 'R2', 'RMSE improvement vs baseline']])\n",
    "\n",
    "rmse_pivot = combined_metrics.pivot(index='Horizon', columns='Model', values='RMSE')\n",
    "rmse_pivot.plot(kind='bar')\n",
    "plt.title('Forecast Accuracy by Horizon: 15-minute vs 1-hour')\n",
    "plt.ylabel('RMSE')\n",
    "plt.xlabel('Forecast horizon')\n",
    "plt.xticks(rotation=0)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
