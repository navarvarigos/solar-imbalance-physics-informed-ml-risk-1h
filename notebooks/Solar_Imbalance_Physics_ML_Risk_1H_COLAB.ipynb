    "\n",
    "- `/content/Solar_Energy_Generation.csv`, `/content/Weather_Data_reordered_all.csv`, `/content/Solar_Site_Details.csv`\n",
    "\n",
    "If your files have slightly different names, rename them in the Colab file panel."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "db3728f3",
   "metadata": {},
   "outputs": [],
   "source": [
    "BASE = Path('/content')\n",
    "ZIP_PATH = BASE / 'archive.zip'\n",
    "DATA_DIR = BASE / 'unisolar'\n",
    "\n",
    "# If archive.zip exists, extract it.\n",
    "if ZIP_PATH.exists():\n",
    "    with zipfile.ZipFile(ZIP_PATH, 'r') as z:\n",
    "        z.extractall(BASE)\n",
    "    print(f\"Extracted {ZIP_PATH} into {BASE}\")\n",
    "else:\n",
    "    print(\"No archive.zip found. Will try to read CSVs directly from /content.\")\n",
    "\n",
    "# Detect where the CSVs are.\n",
    "candidate_dirs = [BASE / 'unisolar', BASE]\n",
    "for d in candidate_dirs:\n",
    "    print(\"Checking:\", d, \"exists=\", d.exists())\n",
    "    if d.exists():\n",
    "        print([p.name for p in d.glob('*.csv')][:10])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "14287cf2",
   "metadata": {},
   "outputs": [],
   "source": [
