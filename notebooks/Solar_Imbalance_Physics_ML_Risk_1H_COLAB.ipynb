    "def plot_largest_negative_ramp_event_1h(event_rank=0, window=12):\n",
    "    local_test = test_1h.reset_index(drop=True).copy()\n",
    "    event_rows = local_test.sort_values(RAMP_1H, ascending=True).head(event_rank + 1)\n",
    "    event_idx = int(event_rows.index[event_rank])\n",
    "\n",
    "    start = max(0, event_idx - window)\n",
    "    end = min(len(local_test), event_idx + window + 1)\n",
    "    event_plot_df = local_test.iloc[start:end].copy()\n",
    "\n",
    "    event_time = local_test.loc[event_idx, 'forecast_valid_time_1h']\n",
    "    event_ramp = local_test.loc[event_idx, RAMP_1H]\n",
    "\n",
    "    plt.figure()\n",
    "    plt.plot(event_plot_df['forecast_valid_time_1h'], event_plot_df[TARGET_1H], label='Actual PV t+1h')\n",
